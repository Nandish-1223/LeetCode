class Solution {
    public double findMedianSortedArrays(int[] nums1, int[] nums2) {
        int n = nums1.length + nums2.length;
        int[] merge = new int[n];
        int i = 0;
        int j = 0;
        int k = 0;
        int mid;
        while(i < nums1.length && j < nums2.length){
            if(nums1[i] < nums2[j]){
                merge[k++] = nums1[i++];
            }
            else{
                merge[k++] = nums2[j++];
            }
        }
        while(i < nums1.length){
            merge[k++] = nums1[i++];
        }
        while(j < nums2.length){
            merge[k++] = nums2[j++];
        }
        mid = n / 2;
        if(n % 2 == 0){
            return (merge[mid - 1] + merge[mid]) / 2.0;
        }
        else{
            return merge[mid];
        }
    }
}
