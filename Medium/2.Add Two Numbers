/**
 * Definition for singly-linked list.
 * public class ListNode {
 *     int val;
 *     ListNode next;
 *     ListNode() {}
 *     ListNode(int val) { this.val = val; }
 *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }
 * }
 */
class Solution {
    public ListNode addTwoNumbers(ListNode l1, ListNode l2) {
        ListNode root;
        ListNode curr;
        int carry = 0;
        int temp = l1.val + l2.val + carry;
        root = new ListNode(temp % 10,null);
        carry = temp / 10;
        l1 = l1.next;
        l2 = l2.next;
        curr = root;
        while(l1 != null && l2 != null){
            ListNode node = new ListNode(0,null);
            temp = l1.val + l2.val + carry;
            node.val = temp % 10;
            carry = temp / 10;
            l1 = l1.next;
            l2 = l2.next;
            curr.next = node;
            curr = node;
        }
        while(l1 != null){
            ListNode node = new ListNode(0,null);
            temp = l1.val + carry;
            node.val = temp % 10;
            carry = temp / 10;
            l1 = l1.next;
            curr.next = node;
            curr = node;
        }
        while(l2 != null){
            ListNode node = new ListNode(0,null);
            temp = l2.val + carry;
            node.val = temp % 10;
            carry = temp / 10;
            l2 = l2.next;
            curr.next = node;
            curr = node;
        }
        if (carry != 0){
            ListNode node = new ListNode(carry,null);
            curr.next = node;
            curr = node;
        }
        return root;
    }
}
