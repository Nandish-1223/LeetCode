class Solution {
    public boolean isPalindrome(int x) {
        if(x < 0){
            return false;
        }
        int t = x;
        int rev = 0,rem = 0;
        while(t!=0){
            rem = t%10;
            rev = rev * 10 + rem;
            t = t/10;
        }
        if(x == rev){
            return true;
        }
        else{
            return false;
        }
    }
}
