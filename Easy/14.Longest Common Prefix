class Solution(object):
    def longestCommonPrefix(self, strs):
        """
        :type strs: List[str]
        :rtype: str
        """
        m = min([len(x) for x in strs])
        temp = 9999999
        c = 0
        for j in range(len(strs)-1):
            c = 0
            for i in range(0,m):
                if strs[j][i] == strs[j+1][i]:
                    c += 1
                else:
                    break
            temp = min(temp,c)          
        return strs[0][0:temp]
